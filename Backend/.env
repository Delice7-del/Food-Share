# Server Configuration
PORT=5002
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://127.0.0.1:27017/foodshare

# JWT Configuration
JWT_SECRET=dev_secret_key_12345
JWT_EXPIRE=30d

# Email Configuration (Mock for dev)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=mock_user
EMAIL_PASS=mock_pass

# Rate Limiting
# Increased to 1000 for debugging/dev to fix 429 errors
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
